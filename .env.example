# 호스트에서 prisma migrate / DB 클라이언트 접속 시 (docker-compose.dev의 postgres 매핑 포트와 동일)
DATABASE_URL=postgresql://nugabox:nugabox@localhost:6042/nugabox_support?schema=public

# JWT (운영에서는 반드시 강한 랜덤 문자열로 교체)
JWT_SECRET=dev-jwt-secret-change-in-production-min-32-chars-long
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=dev-refresh-secret-change-in-production-min-32
REFRESH_TOKEN_EXPIRES_IN=7d

# --- 공개 URL / CORS ---
# 로컬: 프론트에 접속하는 브라우저 주소(포트 포함)와 맞춥니다.
# 운영: 역방향 프록시로 https://support.nugabox.com → 호스트의 localhost:6040(프론트)만 노출하는 경우,
#       사용자가 보는 사이트 루트 URL로 맞춥니다.
# Next 메타데이터(og:image·metadataBase·canonical)는 APP_BASE_URL + /meta_thumbnail.jpg 로 생성합니다.
APP_BASE_URL=http://localhost:6040
# 백엔드 CORS 허용 출처. 운영에서는 프론트 공개 URL과 동일하게 두는 경우가 많습니다.
FRONTEND_ORIGIN=http://localhost:6040
# (선택) 외부 브라우저 앱 등 여러 출처 허용 시 쉼표 구분. 설정 시 FRONTEND_ORIGIN 대신 사용됩니다.
# CORS_ORIGINS=https://support.nugabox.com,https://your-other-app.com
# Next 메타데이터(metadataBase·og:url 등). APP_BASE_URL 미설정 시에만 사용(선택).
NEXT_PUBLIC_SITE_URL=http://localhost:6040
NODE_ENV=development

# 호스트에 노출되는 포트 (컨테이너 내부: 프론트 3000, API 4000, DB 5432)
FRONTEND_PORT=6040
BACKEND_PORT=6041
POSTGRES_PORT=6042

# 업로드
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE_MB=10

# 텔레그램 (비활성 시 알림 스킵)
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- 브라우저 → API (동일 출처 /api 프록시) ---
# Docker 개발/운영 기본: 프론트 공개 URL + /api (Next가 Nest /api 로 리라이트).
# `http://localhost:6040` 처럼 /api 없이 두면 클라이언트에서 자동으로 `/api` 를 붙입니다.
NEXT_PUBLIC_API_URL=http://localhost:6040/api
# Next 서버가 Nest로 넘길 내부 주소. Docker Compose에서는 보통 설정하지 않고 compose가 backend:4000 을 넣습니다.
# 호스트에서만 `next dev` + 백엔드를 6041에 띄울 때 예시:
# INTERNAL_API_ORIGIN=http://127.0.0.1:6041
