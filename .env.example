# 데이터베이스 (Docker 내부 호스트명: postgres)
DATABASE_URL=postgresql://nugabox:nugabox@localhost:5432/nugabox_support?schema=public

# JWT (운영에서는 반드시 강한 랜덤 문자열로 교체)
JWT_SECRET=dev-jwt-secret-change-in-production-min-32-chars-long
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=dev-refresh-secret-change-in-production-min-32
REFRESH_TOKEN_EXPIRES_IN=7d

# 앱
APP_BASE_URL=http://localhost:3000
FRONTEND_ORIGIN=http://localhost:3000
NODE_ENV=development

# 포트 (compose에서 주입 가능)
FRONTEND_PORT=3000
BACKEND_PORT=4000

# 업로드
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE_MB=10

# 텔레그램 (비활성 시 알림 스킵)
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 프론트 → 백엔드 URL (브라우저에서 접근 가능한 URL)
NEXT_PUBLIC_API_URL=http://localhost:4000
