# 호스트에서 prisma migrate / DB 클라이언트 접속 시 (docker-compose.dev의 postgres 매핑 포트와 동일)
DATABASE_URL=postgresql://nugabox:nugabox@localhost:6042/nugabox_support?schema=public

# JWT (운영에서는 반드시 강한 랜덤 문자열로 교체)
JWT_SECRET=dev-jwt-secret-change-in-production-min-32-chars-long
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=dev-refresh-secret-change-in-production-min-32
REFRESH_TOKEN_EXPIRES_IN=7d

# 앱 (브라우저·CORS·텔레그램 링크에 사용)
APP_BASE_URL=http://localhost:6040
FRONTEND_ORIGIN=http://localhost:6040
NODE_ENV=development

# 호스트에 노출되는 포트 (컨테이너 내부: 프론트 3000, API 4000, DB 5432)
FRONTEND_PORT=6040
BACKEND_PORT=6041
POSTGRES_PORT=6042

# 업로드
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE_MB=10

# 텔레그램 (비활성 시 알림 스킵)
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 프론트 빌드/브라우저에서 API 접근 URL
NEXT_PUBLIC_API_URL=http://localhost:6041
